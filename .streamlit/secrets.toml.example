# Prefer TMDB's read access token (Bearer authentication).
# Create one at https://www.themoviedb.org/settings/api and copy this file to
# .streamlit/secrets.toml. The real secrets.toml is ignored by git.
TMDB_BEARER_TOKEN = "paste_your_tmdb_read_access_token_here"

# Legacy API v3 keys are supported too, if needed:
# TMDB_API_KEY = "paste_your_tmdb_api_key_here"
